  m_text: "- \uC5D4\uB529 \uD06C\uB808\uB527 -\n\n\n\uC81C\uC791 : \uC1A1\uADFC\uD615\n\n\n-
    \uACE0\uB9C8\uC6B4 \uBD84\uB4E4 -\n\n\n\uAE40\uC7AC\uC131 \uAC15\uC0AC\uB2D8\n\n\uCD5C\uC601\uBBFC
    \uAC15\uC0AC\uB2D8\n\n\uC774\uD0DC\uD638 \uB9E4\uB2C8\uC800\uB2D8\n\n\uC9C4\uC720\uB85D
    \uB9E4\uB2C8\uC800\uB2D8\n\nDEVELROCKET\uC758 \uBAA8\uB4E0 \uBD84\uB4E4\n\n-
    Assets Provided By -\n\n\u2022 \uB125\uC2A8 \uBA54\uC774\uD50C\uC2A4\uD1A0\uB9AC
    \uD3F0\uD2B8\nProvided By (\uC8FC)\uB125\uC2A8\uCF54\uB9AC\uC544\n\n\u2022 \uC5B8\uB370\uB4DC
    \uC11C\uBC14\uC774\uBC84 \uC5D0\uC14B \uD329\nProvided By \uACE8\uB4DC\uBA54\uD0C8\n\n\u2022
    \uBCFC\uD2B8 2D \uB9AC\uD2C0\uC6CC\uC988 \uC5D0\uC14B \uD329\nProvided By \uACE8\uB4DC\uBA54\uD0C8\n\n\u2022
